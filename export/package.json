{
  "name": "@signup/export",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.jsonc",
    "deploy": "echo 'Error: Please use deploy:staging or deploy:production' && exit 1",
    "deploy:staging": "wrangler deploy --env staging --config wrangler.jsonc",
    "deploy:production": "wrangler deploy --env production --config wrangler.jsonc",
    "build": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.60.0"
  }
}
